{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contributors": ["TODO"],
    "contact": {
        "homepage": "${display_url}",
        "issues": "${issue_tracker_url}"
    },
    "license": "${license}",
    "icon": "${mod_id}.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.github.andrew0030.pandora_core.PandoraCoreFabric"
        ],
        "client": [
            "com.github.andrew0030.pandora_core.PandoraCoreClientFabric"
        ],
        "modmenu": [
            "com.github.andrew0030.pandora_core.config.factories.ModMenuConfigFactory"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": "${fabric_loader_version_range}",
        "fabric-api": "*",
        "minecraft": "${fabric_minecraft_version_range}",
        "java": ">=${java_version}"
    },
    "custom": {
        "pandoracore": {
            "icon": "${mod_id}.png",
            "background": "background.png",
            "blurIcon": false,
            "updateURL": "https://raw.githubusercontent.com/andrew0030/Pandoras-Creatures/refs/heads/1.16.5/src/main/resources/assets/pandoras_creatures/update.json",
            "warningFactory": "com.github.andrew0030.pandora_core.utils.mod_warnings.PaCoWarningFactory",
            "configFactory": "com.github.andrew0030.pandora_core.config.factories.SimpleConfigFactory"
        },
        "catalogue": {
            "configFactory": "com.github.andrew0030.pandora_core.config.factories.SimpleConfigFactory"
        }
    }
}